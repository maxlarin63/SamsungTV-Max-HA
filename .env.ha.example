# Copy this file to .env.ha and fill in your values.
# .env.ha is git-ignored.

# Required — IP or hostname of your Home Assistant instance
HA_HOST=192.168.1.100

# Optional — SSH user (defaults to root)
# HA_USER=root

# Optional — path to SSH private key (defaults to %USERPROFILE%\.ssh\ha_deploy on Windows,
# ~/.ssh/ha_deploy on Linux/macOS/WSL if the file exists)
# HA_SSH_IDENTITY=

# Optional — HA base URL + long-lived token to trigger restart after deploy
# HA_HTTP_URL=http://homeassistant.local:8123
# HA_TOKEN=your_long_lived_token_here
